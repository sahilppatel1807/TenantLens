# Copy to `.env.local` — never commit `.env.local`.

# Public (safe in the browser; bundled as NEXT_PUBLIC_*). RLS still applies.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Either key name works (same value from Supabase → API settings).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional, server-only: service role bypasses RLS — never prefix with NEXT_PUBLIC_
# or import it in client components. Use only in trusted server code if you add it.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Playwright signed-in smoke test (e2e/smoke.spec.ts)
# E2E_EMAIL=you@example.com
# E2E_PASSWORD=your-password
